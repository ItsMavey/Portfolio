---
interface Props {
    href: string;
    text: string;
    width?: string;
    height?: string;
}

const {href, text, width, height} = Astro.props;
---


<a href={href} style={`${width ? `width: ${width};` : ''}${height ? `height: ${height};` : ''}`}>
    <span>{text}</span>
</a>


<style>
    a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: .7rem 1.75rem;
        border-radius: 999px;
        font-size: 15px;
        font-weight: 500;
        text-decoration: none;
        color: var(--bg-color);
        background: var(--primary-green);

        position: relative;
        overflow: hidden;

        transition: color 0.25s, transform 80ms ease;
    }

    a span {
        position: relative;
        z-index: 1;
    }

    a::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: var(--deep-green);
        transform: translateY(100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 0;
    }

    a:hover {
        color: var(--text-main);
    }

    a:hover::before {
        transform: translateY(0);
    }

    a:active {
        transform: scale(0.97);
    }

    a:focus-visible {
        outline: 2px solid var(--primary-green);
        outline-offset: 3px;
    }
</style>