---
import type { CollectionEntry } from 'astro:content';
import SectionHeading from '../SectionHeading.astro';
import PrimaryButton from '../ui/buttons/primaryButton.astro';

interface Props {
    projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section id="projects">
    <SectionHeading title="Projects" />

    <div>
        {projects.map((project, index) => (
            <article class:list={["scroll-reveal", { featured: project.data.featured }]} style={`--index: ${index}`}>
                <div>
                    <time>{project.data.year}</time>
                    <h3>{project.data.title}</h3>
                    <p>{project.data.description}</p>

                    <footer>
                        <div>
                            {project.data.tags.map((tag) => (
                                <span>{tag}</span>
                            ))}
                        </div>

                        <nav>
                            {project.data.githubUrl && (
                                <a href={project.data.githubUrl} rel="noopener noreferrer" target="_blank" aria-label="View on GitHub">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                                    </svg>
                                </a>
                            )}
                            {project.data.blogSlug && (
                                <PrimaryButton href={`/blog/${project.data.blogSlug}`} text="Learn more" />
                            )}
                        </nav>
                    </footer>
                </div>
            </article>
        ))}
    </div>
</section>

<style>
    section > div {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 3rem;
    }

    article {
        background: rgba(17, 24, 39, 0.4);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        overflow: hidden;
    }

    article.featured {
        border-color: rgba(16, 185, 129, 0.25);
        box-shadow: 0 0 20px -5px rgba(16, 185, 129, 0.15);
    }

    article:hover {
        transform: translateY(-6px);
        border-color: rgba(16, 185, 129, 0.4);
        box-shadow: 0 15px 35px -15px rgba(16, 185, 129, 0.3);
    }

    article > div {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    time {
        display: block;
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: var(--primary-green);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
    }

    h3 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.4rem;
        color: var(--text-main);
        margin: 0 0 0.75rem 0;
    }

    p {
        color: var(--text-muted);
        line-height: 1.6;
        margin: 0 0 1.5rem 0;
        flex-grow: 1;
    }

    footer {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    footer > div {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    footer > div > span {
        display: inline-block;
        padding: 0.25rem 0.65rem;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: var(--text-muted);
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 999px;
    }

    footer > nav {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    footer > nav > a {
        color: var(--text-muted);
        transition: color 0.2s ease;
        display: inline-flex;
    }

    footer > nav > a:hover {
        color: var(--text-main);
    }

    @media (max-width: 768px) {
        section > div {
            grid-template-columns: 1fr;
        }
    }
</style>
