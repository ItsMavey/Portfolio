---
import PrimaryButton from '../ui/buttons/primaryButton.astro';
import SecondaryButton from '../ui/buttons/secondaryButton.astro';
---

<header>
    <div class="hero-content parallax" style="--parallax-speed: 0.3">
        <div class="page-reveal">
            <h1>Adam Ousmer</h1>
            <span class="page-title-line"></span>
        </div>
        <h2 class="page-stagger">Software Engineering Student at Concordia University</h2>

        <p class="page-stagger">
            I build things for the web and study how software systems work end to end.
            Currently focused on full-stack development, infrastructure, and interface design.
        </p>

        <div class="hero-buttons page-stagger">
            <PrimaryButton href="/contact" text="Contact me" width="150px" height="40px" />
            <SecondaryButton href="/#projects" text="Projects" width="150px" height="40px" />
        </div>

        <a href="#skills" class="scroll-indicator page-stagger" aria-label="Scroll to Skills Section">
            <div class="mouse"></div>
            <p>Scroll</p>
        </a>
    </div>
</header>

<style>
    header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }

    .hero-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        width: 100%;
        /* Let Lenis/scroll.js transform work smoothly */
        will-change: transform;
    }

    .hero-content h1 {
        font-size: 3rem;
        margin: 0.5rem 0;
        color: var(--text-main);
    }

    .hero-content h2 {
        font-size: 1.5rem;
        margin: 0.5rem 0;
        font-weight: 400;
        color: var(--text-main);
    }

    .hero-content p {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1rem;
        line-height: 1.7;
        color: var(--text-muted);
        max-width: 520px;
        margin: 1rem 0;
        text-align: center;
    }

    .hero-buttons {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .scroll-indicator {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-top: 6rem;
        opacity: 0.6;
        transition: opacity 0.3s ease;
        text-decoration: none;
    }

    .scroll-indicator:hover {
        opacity: 1;
    }

    .scroll-indicator p {
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin: 0;
        color: var(--text-muted);
    }

    .mouse {
        width: 20px;
        height: 32px;
        border: 2px solid var(--text-muted);
        border-radius: 12px;
        position: relative;
        display: flex;
        justify-content: center;
    }

    .mouse::before {
        content: '';
        position: absolute;
        top: 6px;
        width: 4px;
        height: 4px;
        background-color: var(--primary-green);
        border-radius: 50%;
        animation: scrollWheel 2s infinite cubic-bezier(0.15, 0.41, 0.69, 0.94);
    }

    @keyframes scrollWheel {
        0% { transform: translateY(0); opacity: 1; }
        100% { transform: translateY(12px); opacity: 0; }
    }

    @media (min-width: 768px) {
        .scroll-indicator {
            margin-top: 10rem;
        }
        .mouse {
            width: 24px;
            height: 36px;
        }
        .mouse::before {
            width: 4px;
            height: 6px;
            border-radius: 2px;
        }
        @keyframes scrollWheel {
            0% { transform: translateY(0); opacity: 1; }
            100% { transform: translateY(14px); opacity: 0; }
        }
    }
</style>

<script src="../../scripts/page-entrance.js"></script>
