---
import Layout from '../layouts/layout.astro';
import Nodes from '../components/layout/node.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, t } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);

import HeroSection from '../components/sections/HeroSection.astro';
import SkillsSection from '../components/sections/SkillsSection.astro';
import TimelineSection from '../components/sections/TimelineSection.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import CoursesSection from '../components/sections/CoursesSection.astro';

const projects = (await getCollection('projects')).sort(
    (a, b) => b.data.year - a.data.year
);

const courses = (await getCollection('courses')).sort(
    (a, b) => b.data.year - a.data.year
);

const timeline = [
    {
        year: 'January, 2022',
        title: 'Built my first AI project',
        description: 'Developed an AI program from scratch without using any external libraries, exploring core neural networks concepts just 3 months into my coding journey.',
        type: 'project' as const,
    },
    {
        year: 'September, 2022',
        title: 'Started Software Engineering at Concordia University',
        description: 'Enrolled in the Bachelor of Engineering in Software Engineering program.',
        type: 'education' as const,
    },
    {
        year: 'September, 2022',
        title: 'Joined Space Concordia - Rocketry Division',
        description: 'Created my first script for calibrating sensors',
        type: 'education' as const,
    },
    {
        year: 'October, 2022',
        title: 'CodeML - Hackathon',
        description: 'Finish second place without a team on the CGI Challenge in AI',
        type: 'project' as const,
    },
    {
        year: 'May, 2022',
        title: 'Independent Research',
        description: 'Join Dr. Ali Janaptour and Dr. Constantinos Constantinides in research in Formal Methods',
        type: 'project' as const,
        ongoing: true,
    },
    {
        year: 'October, 2022',
        title: 'Development of ThrustOptima',
        description: 'Creating a completing new tool for non-destructive analysis of a combustion chamber using a CT Scan',
        type: 'project' as const,
        ongoing: true,
    },
    {
        year: 'July, 2025',
        title: 'Development of GUIToolkit',
        description: 'Creating a GUI framework for Minecraft plugin with Orisis Studio',
        type: 'project' as const,
    },
    {
        year: 'October, 2025',
        title: 'Development of ItsBagelBot',
        description: 'Development of a Microservice Architecture for a Twitch bot including Zero-trust Architecture, k3s and Oracle Cloud',
        type: 'project' as const,
        ongoing: true,
    },
    {
        year: 'April, 2026',
        title: 'Infrastructure Launch',
        description: 'Launched test applications from course classes on ItsBagelBot to test the k3s, Cloudflare, NewRelic and Tailscale environments on Oracle Compute instances',
        type: 'project' as const,
    },

];
---

<Layout title={t(lang, 'meta.home.title')} description={t(lang, 'meta.home.description')} lang={lang}>
    <Nodes />
    <HeroSection />

    <main>
        <SkillsSection />
        <TimelineSection entries={timeline} />
        <ProjectsSection projects={projects} />
        <CoursesSection courses={courses} />
    </main>
</Layout>